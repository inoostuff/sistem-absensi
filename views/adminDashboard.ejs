<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Dashboard Admin</h2>
            <a href="/logout" class="btn btn-danger">Logout</a>
        </div>

        <ul class="nav nav-tabs mb-3" id="myTab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="users-tab" data-bs-toggle="tab" data-bs-target="#users" type="button">Daftar User</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="attendance-tab" data-bs-toggle="tab" data-bs-target="#attendance" type="button">Semua Absensi</button>
            </li>
        </ul>

        <div class="tab-content">
            <!-- Tab User -->
            <div class="tab-pane fade show active" id="users">
                <div class="card">
                    <div class="card-header">User Terdaftar</div>
                    <div class="card-body">
                        <table class="table">
                            <thead><tr><th>Username</th><th>Role</th></tr></thead>
                            <tbody>
                                <% users.forEach(u => { %>
                                <tr><td><%= u.username %></td><td><%= u.role %></td></tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Tab Absensi -->
            <div class="tab-pane fade" id="attendance">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Rekap Absensi</span>
                        <div>
                            <input type="date" id="filterDate" class="form-control form-control-sm d-inline-block w-auto">
                            <button id="filterBtn" class="btn btn-sm btn-primary">Filter</button>
                        </div>
                    </div>
                    <div class="card-body">
                        <table class="table table-bordered" id="attTable">
                            <thead><tr><th>User</th><th>Tanggal</th><th>Waktu Absen</th><th>Status</th></tr></thead>
                            <tbody>
                                <% attendances.forEach(att => { %>
                                <tr>
                                    <td><%= att.userId.username %></td>
                                    <td><%= att.date %></td>
                                    <td><%= new Date(att.checkIn).toLocaleTimeString() %></td>
                                    <td><%= att.status %></td>
                                </tr>
                                <% }) %>
                                <% if (attendances.length === 0) { %>
                                <tr><td colspan="4">Belum ada data absensi</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('filterBtn').addEventListener('click', async () => {
            const date = document.getElementById('filterDate').value;
            let url = '/api/attendances';
            if (date) url += `?date=${date}`;
            const res = await fetch(url);
            const data = await res.json();
            const tbody = document.querySelector('#attTable tbody');
            tbody.innerHTML = '';
            if (data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4">Tidak ada data</td></tr>';
                return;
            }
            data.forEach(att => {
                const row = `<tr>
                    <td>${att.userId.username}</td>
                    <td>${att.date}</td>
                    <td>${new Date(att.checkIn).toLocaleTimeString()}</td>
                    <td>${att.status}</td>
                </tr>`;
                tbody.insertAdjacentHTML('beforeend', row);
            });
        });
    </script>
</body>
</html>